<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    /* Example styling for validation feedback */
    input:valid, select:valid {
      border-color: #28a745;
    }
    input:invalid, select:invalid {
      border-color: #dc3545;
    }
    .error-message {
      color: #dc3545;
      font-size: 0.9em;
    }
  </style>
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const form = document.getElementById("addInventoryForm");
      const inputs = form.querySelectorAll("input, select");

      // Live validation feedback
      inputs.forEach(input => {
        input.addEventListener("input", () => {
          if (input.checkValidity()) {
            input.classList.add("valid");
            input.classList.remove("invalid");
          } else {
            input.classList.add("invalid");
            input.classList.remove("valid");
          }
        });
      });

      form.addEventListener("submit", (event) => {
        if (!form.checkValidity()) {
          event.preventDefault();
          form.reportValidity();
        }
      });
    });
  </script>
</head>
<body>
  <main>
    <h1>Add New Vehicle</h1>

    <% if (flashMessage) { %>
      <div class="alert alert-danger"><%= flashMessage %></div>
    <% } %>
    <% if (errors && errors.length > 0) { %>
      <div class="alert alert-danger">
        <ul>
          <% errors.forEach(error => { %>
            <li><%= error.msg %></li>
          <% }) %>
        </ul>
      </div>
    <% } %>

    <form id="addInventoryForm" action="/inv/add-inventory" method="post">
      <!-- Make -->
      <div class="form-group">
        <label for="invMake">Make:</label>
        <input type="text" id="invMake" name="inv_make" 
               value="<%= inv_make %>" required minlength="1">
      </div>

      <!-- Model -->
      <div class="form-group">
        <label for="invModel">Model:</label>
        <input type="text" id="invModel" name="inv_model" 
               value="<%= inv_model %>" required minlength="1">
      </div>

      <!-- Year -->
      <div class="form-group">
        <label for="invYear">Year:</label>
        <input type="number" id="invYear" name="inv_year" 
               value="<%= inv_year %>" required min="1900" max="<%= new Date().getFullYear() + 1 %>" step="1">
      </div>

      <!-- Description -->
      <div class="form-group">
        <label for="invDescription">Description:</label>
        <textarea id="invDescription" name="inv_description" rows="4" required><%= inv_description %></textarea>
      </div>

      <!-- Image -->
      <div class="form-group">
        <label for="invImage">Image Path:</label>
        <input type="text" id="invImage" name="inv_image" value="<%= inv_image %>" placeholder="/images/vehicle.jpg">
      </div>

      <!-- Thumbnail -->
      <div class="form-group">
        <label for="invThumbnail">Thumbnail Path:</label>
        <input type="text" id="invThumbnail" name="inv_thumbnail" value="<%= inv_thumbnail %>" placeholder="/images/vehicle-tn.jpg">
      </div>

      <!-- Price -->
      <div class="form-group">
        <label for="invPrice">Price:</label>
        <input type="number" id="invPrice" name="inv_price" 
               value="<%= inv_price %>" required min="0" step="0.01">
      </div>

      <!-- Miles -->
      <div class="form-group">
        <label for="invMiles">Miles:</label>
        <input type="number" id="invMiles" name="inv_miles" 
               value="<%= inv_miles %>" required min="0" step="1">
      </div>

      <!-- Color -->
      <div class="form-group">
        <label for="invColor">Color:</label>
        <input type="text" id="invColor" name="inv_color" 
               value="<%= inv_color %>" required minlength="1">
      </div>

      <!-- Classification Dropdown -->
      <div class="form-group">
        <label for="classificationList">Classification:</label>
        <%- classificationList %>
      </div>

      <button type="submit" class="btn">Add Vehicle</button>
    </form>
  </main>
</body>
</html>