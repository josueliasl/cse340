<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/css/styles.css">
</head>

<body>
    <%- include('../partials/header') %>
        <main>
            <h1>
                <%= title %>
            </h1>

            <% if (flashMessage) { %>
                <div class="flash-message flash-success">
                    <%= flashMessage %>
                </div>
                <% } %>

                    <div class="management-links">
                        <a href="/inv/add-classification" class="button">Add New Classification</a>
                        <a href="/inv/add-inventory" class="button">Add New Vehicle</a>
                    </div>

                    <h2>Manage Inventory</h2>
                    <p>Select a classification from the list below to see the items belonging to that classification.
                    </p>

                    <!-- Classification select list -->
                    <div class="classification-select">
                        <%- classificationSelect %>
                    </div>

                    <!-- Empty table for inventory display -->
                    <table id="inventoryDisplay">
                        <!-- JavaScript will populate this table -->
                    </table>

                    <noscript>JavaScript must be enabled to use this page.</noscript>
        </main>
        <%- include('../partials/footer') %>

            <script src="/js/inventory.js"></script>
</body>

</html>