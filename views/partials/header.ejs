<header id="top-header">
  <div class="head">
    <h1 class="siteName">
      CSE Motors
    </h1>
    <div id="tools">
      <% if (locals.loggedin) { %>
        <span class="welcome-link">
          <a href="/account/" title="Go to your account">Welcome <%= locals.accountData.account_firstname %></a>
        </span>
        <a href="/account/logout" title="Log out">Logout</a>
        <% } else { %>
          <a href="/account/login" title="Click to log in">My Account</a>
          <% } %>
    </div>
  </div>
</header>