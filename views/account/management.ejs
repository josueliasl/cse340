<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/css/styles.css">
</head>

<body>
    <%- include('../partials/header') %>
        <main>
            <h1>
                <%= title %>
            </h1>

            <% if (locals.messages && locals.messages.success) { %>
                <div class="flash-message flash-success">
                    <%= messages.success %>
                </div>
                <% } %>
                    <% if (locals.messages && locals.messages.error) { %>
                        <div class="flash-message flash-error">
                            <%= messages.error %>
                        </div>
                        <% } %>
                            <% if (locals.messages && locals.messages.notice) { %>
                                <div class="flash-message flash-notice">
                                    <%= messages.notice %>
                                </div>
                                <% } %>

                                    <% if (accountData && accountData.account_type==='Client' ) { %>
                                        <h2>Welcome <%= accountData.account_firstname %>
                                        </h2>
                                        <% } else if (accountData && (accountData.account_type==='Employee' ||
                                            accountData.account_type==='Admin' )) { %>
                                            <h2>Welcome <%= accountData.account_firstname %>
                                            </h2>
                                            <h3>Inventory Management</h3>
                                            <p><a href="/inv/">Manage Inventory</a></p>
                                            <% } %>

                                                <p><a href="/account/update/<%= accountData.account_id %>">Update
                                                        Account Information</a></p>
        </main>

</body>

</html>